<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardProduct"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp">

        <!-- Product image -->
        <ImageView
            android:id="@+id/ivProduct"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:scaleType="centerCrop"
            android:background="#EEEEEE"
            android:src="@drawable/ic_image_placeholder"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Name -->
        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#212121"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivProduct"
            app:layout_constraintEnd_toStartOf="@id/btnEditProduct"
            android:layout_marginStart="8dp" />

        <!-- Price -->
        <TextView
            android:id="@+id/tvProductPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#616161"
            app:layout_constraintTop_toBottomOf="@id/tvProductName"
            app:layout_constraintStart_toEndOf="@id/ivProduct"
            app:layout_constraintEnd_toStartOf="@id/btnEditProduct"
            android:layout_marginStart="8dp"
            android:layout_marginTop="2dp" />

        <!-- Stock (goes red when low) -->
        <TextView
            android:id="@+id/tvProductStock"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tvProductPrice"
            app:layout_constraintStart_toEndOf="@id/ivProduct"
            app:layout_constraintEnd_toStartOf="@id/btnEditProduct"
            android:layout_marginStart="8dp"
            android:layout_marginTop="2dp" />

        <!-- Quick-adjust row -->
        <ImageButton
            android:id="@+id/btnDecrement"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_input_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Decrease stock"
            app:layout_constraintTop_toBottomOf="@id/tvProductStock"
            app:layout_constraintStart_toEndOf="@id/ivProduct"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp" />

        <EditText
            android:id="@+id/etStockAdjust"
            android:layout_width="52dp"
            android:layout_height="32dp"
            android:hint="1"
            android:inputType="number"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@android:drawable/editbox_background"
            app:layout_constraintTop_toBottomOf="@id/tvProductStock"
            app:layout_constraintStart_toEndOf="@id/btnDecrement"
            app:layout_constraintEnd_toStartOf="@id/btnIncrement"
            android:layout_marginTop="4dp" />

        <ImageButton
            android:id="@+id/btnIncrement"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_input_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Increase stock"
            app:layout_constraintTop_toBottomOf="@id/tvProductStock"
            app:layout_constraintEnd_toStartOf="@id/btnEditProduct"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="4dp" />

        <!-- Edit and Delete icons on the right -->
        <ImageButton
            android:id="@+id/btnEditProduct"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Edit"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageButton
            android:id="@+id/btnDeleteProduct"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Delete"
            app:layout_constraintTop_toBottomOf="@id/btnEditProduct"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
