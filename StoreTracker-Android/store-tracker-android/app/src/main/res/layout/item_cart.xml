<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp">

        <!-- Product name -->
        <TextView
            android:id="@+id/tvCartItemName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#212121"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnCartRemove" />

        <!-- Unit price -->
        <TextView
            android:id="@+id/tvCartUnitPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#757575"
            app:layout_constraintTop_toBottomOf="@id/tvCartItemName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnCartRemove"
            android:layout_marginTop="2dp" />

        <!-- Quantity controls -->
        <ImageButton
            android:id="@+id/btnCartMinus"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_input_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Decrease"
            app:layout_constraintTop_toBottomOf="@id/tvCartUnitPrice"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvCartQty"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#212121"
            app:layout_constraintTop_toBottomOf="@id/tvCartUnitPrice"
            app:layout_constraintStart_toEndOf="@id/btnCartMinus"
            app:layout_constraintEnd_toStartOf="@id/btnCartPlus"
            android:layout_marginTop="4dp" />

        <ImageButton
            android:id="@+id/btnCartPlus"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_input_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Increase"
            app:layout_constraintTop_toBottomOf="@id/tvCartUnitPrice"
            app:layout_constraintStart_toEndOf="@id/tvCartQty"
            android:layout_marginTop="4dp" />

        <!-- Subtotal -->
        <TextView
            android:id="@+id/tvCartSubtotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/colorAccent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnCartRemove"
            android:layout_marginEnd="8dp" />

        <!-- Remove button -->
        <ImageButton
            android:id="@+id/btnCartRemove"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Remove"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
